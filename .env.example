# Gmail Configuration
GMAIL_ADDRESS=your-company@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# OpenAI
OPENAI_API_KEY=sk-...

# Google Sheets
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json

# Database (PostgreSQL - automatically set by docker-compose)
DATABASE_URL=postgresql://irwt:irwt_password@db:5432/irwt

# App Settings
SECRET_KEY=your-secret-key-here
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
